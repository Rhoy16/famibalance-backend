# Cadena de conexión a PostgreSQL
# En desarrollo local: postgresql://USER:PASSWORD@localhost:5432/DB_NAME
# En producción (Render): obtenla del panel Environment de tu servicio
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME"

# Puerto del servidor Express (Render lo inyecta automáticamente)
PORT=5000

# Secreto para firmar tokens JWT — usa un valor aleatorio y largo en producción
JWT_SECRET="reemplaza_con_un_secreto_seguro"
